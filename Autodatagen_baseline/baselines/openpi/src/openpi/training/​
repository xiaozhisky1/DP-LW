@dataclasses.dataclass
class FilteringWeightLoader(weight_loaders.WeightLoader):
    """
    包装器：从基础加载器加载权重，将需过滤的参数替换为占位符。
    这既能骗过 check_pytree_equality 的结构检查，
    又能利用 train_val.py 的后续逻辑让这些参数保持随机初始化。
    """
    base_loader: weight_loaders.CheckpointWeightLoader 
    exclude_patterns: Sequence[str] = ()

    def load(self, params_shape: at.Params) -> at.Params:
        # 1. 加载 (包含形状不匹配的权重)
        loaded = self.base_loader.load(params_shape)
        
        # 2. 扁平化以便处理
        flat_loaded = traverse_util.flatten_dict(loaded)
        flat_shape = traverse_util.flatten_dict(params_shape)
        
        filtered_flat = {}
        
        for key_tuple, value in flat_loaded.items():
            key_str = "/".join(map(str, key_tuple))
            
            # 检查是否需要过滤
            if any(pattern in key_str for pattern in self.exclude_patterns):
                # === 关键修改 ===
                # 不要跳过(continue)，而是从 params_shape 中取回原始的 ShapeDtypeStruct 占位符填回去。
                # 这样结构(Keys)就对上了，但值是占位符。
                if key_tuple in flat_shape:
                    filtered_flat[key_tuple] = flat_shape[key_tuple]
                    logging.info(f"FilteringWeightLoader: Resetting {key_str} to random init (placeholder)")
            else:
                filtered_flat[key_tuple] = value
                
        return traverse_util.unflatten_dict(filtered_flat)
    

@dataclasses.dataclass
class ProcessX7sData:
    """
    X7s Data Preprocessing (Mask Fix):
    1. Outputs (H, W, C) for images.
    2. Outputs scalar () for masks.
    """
    def __call__(self, data: dict) -> dict:
        def _to_numpy(x):
            if isinstance(x, torch.Tensor):
                return x.detach().cpu().numpy()
            return x

        def _fix_image_shape(key, x):
            # 1. 调整 Channel 顺序 -> (..., 3)
            if x.shape[0] == 3: 
                # (3, H, W) -> (H, W, 3)
                if x.ndim == 3:
                    x = x.transpose(1, 2, 0)
            elif x.ndim >= 4 and x.shape[1] == 3:
                # (T, 3, H, W) -> (T, H, W, 3)
                x = x.transpose(0, 2, 3, 1)
            
            # 2. 获取 H, W, C
            H, W, C = x.shape[-3], x.shape[-2], x.shape[-1]
            
            # 3. 强制重塑为 3 维 (H, W, C)
            x = x.reshape(H, W, C)
            
            return x

        # === 1. 处理图像 ===
        if "image" in data and isinstance(data["image"], dict):
            for k, v in data["image"].items():
                x = _to_numpy(v)
                x = _fix_image_shape(k, x)

                # 类型转换 float -> uint8
                if x.dtype == np.float32 or x.dtype == np.float64:
                    if x.max() <= 1.0: x = (x * 255).astype(np.uint8)
                    else: x = x.astype(np.uint8)
                
                data["image"][k] = x
            
            # === 修复点：创建标量 mask ===
            # 之前是 np.array([True]) -> (1,) -> batch后 (B, 1) -> 报错
            # 现在是 np.array(True)  -> ()   -> batch后 (B,)   -> 通过
            if "image_mask" not in data:
                data["image_mask"] = {k: np.array(True) for k in data["image"]}

        # === 2. 处理状态 ===
        if "state" in data:
            s = _to_numpy(data["state"])
            # 如果是 (1, D) -> (D,)
            if s.ndim == 2 and s.shape[0] == 1:
                s = s.squeeze(0)
            data["state"] = s.astype(np.float32)

        return data
    
